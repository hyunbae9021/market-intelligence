# ── 필수 ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── 선택 (없으면 해당 기능 제한) ──
COINGECKO_API_KEY=       # https://www.coingecko.com/api → 무료 Demo 키 발급
DART_API_KEY=            # https://opendart.fss.or.kr → 무료 (한국 기업 공시)
GITHUB_TOKEN=            # https://github.com/settings/tokens → rate limit 증가용
CRYPTOPANIC_KEY=         # https://cryptopanic.com/developers/api → 무료 티어

# ── 서버 설정 ──
HOST=0.0.0.0
PORT=8000
